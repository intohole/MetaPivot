# ============ 部署规模（资源可伸缩）============
# DB_BACKEND: sqlite（单机/小企业）| postgresql（多实例/大型企业）
# CACHE_BACKEND: memory（单机）| redis（多实例）
# VECTOR_BACKEND: local（单机/小规模）| milvus（百万级 chunk）
#
# ── 小企业零外部依赖部署（推荐起步）──
DB_BACKEND=sqlite
CACHE_BACKEND=memory
VECTOR_BACKEND=local
SQLITE_PATH=data/metapivot.db
#
# ── 中型企业（多实例需共享缓存）──
# DB_BACKEND=postgresql
# CACHE_BACKEND=redis
# VECTOR_BACKEND=local
#
# ── 超大型企业（百万级知识库）──
# DB_BACKEND=postgresql
# CACHE_BACKEND=redis
# VECTOR_BACKEND=milvus

# ============ LLM 配置 ============
LLM_PROVIDER=kimi
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_MODEL=kimi-k2-6
LLM_TIMEOUT=60
LLM_MAX_STEPS=10
LLM_TEMPERATURE=0.3

# ============ 数据库（DB_BACKEND=postgresql 时使用）============
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=metapivot
POSTGRES_USER=metapivot
POSTGRES_PASSWORD=changeme_strong_password

# ============ Redis（CACHE_BACKEND=redis 时使用）============
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============ Milvus（VECTOR_BACKEND=milvus 时使用）============
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=knowledge_chunks

# ============ 钉钉 ============
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ENABLED=false

# ============ 企业微信 ============
WECOM_CORP_ID=
WECOM_APP_SECRET=
WECOM_AGENT_ID=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_ENABLED=false

# ============ 飞书 ============
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ENABLED=false

# ============ 安全 ============
JWT_SECRET=please_change_this_to_random_64_chars_string_at_least
# 轮换时填旧密钥（留空表示无轮换）
JWT_SECRET_PREVIOUS=
# 主密钥标识（用于 kid header，默认 primary）
JWT_KID_PRIMARY=primary
JWT_EXPIRES_IN=3600
JWT_ALGORITHM=HS256
ENCRYPT_KEY=please_change_32_chars_key_random!!!

# ============ 服务 ============
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_LOG_RETENTION_DAYS=3
# 日志格式：text（开发彩色，按 request_id 分流）/ json（生产结构化，ELK/Loki 友好）
APP_LOG_FORMAT=text

# ============ 限流 ============
RATE_LIMIT_IM_QPS=20
RATE_LIMIT_API_QPS=60

# ============ HITL ============
HITL_TIMEOUT_SECONDS=300
