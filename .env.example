# ============ LLM 配置 ============
LLM_PROVIDER=kimi
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_MODEL=kimi-k2-6
LLM_TIMEOUT=60
LLM_MAX_STEPS=10
LLM_TEMPERATURE=0.3

# ============ 数据库 ============
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=metapivot
POSTGRES_USER=metapivot
POSTGRES_PASSWORD=changeme_strong_password

# ============ Redis ============
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============ Milvus ============
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=knowledge_chunks

# ============ 钉钉 ============
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ENABLED=false

# ============ 企业微信 ============
WECOM_CORP_ID=
WECOM_APP_SECRET=
WECOM_AGENT_ID=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_ENABLED=false

# ============ 飞书 ============
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ENABLED=false

# ============ 安全 ============
JWT_SECRET=please_change_this_to_random_64_chars_string_at_least
JWT_EXPIRES_IN=3600
JWT_ALGORITHM=HS256
ENCRYPT_KEY=please_change_32_chars_key_random!!!

# ============ 服务 ============
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_LOG_RETENTION_DAYS=3

# ============ 限流 ============
RATE_LIMIT_IM_QPS=20
RATE_LIMIT_API_QPS=60

# ============ HITL ============
HITL_TIMEOUT_SECONDS=300
